# WAGI Backend Environment
# Copy to backend/.env and update values.

# -------- Provider defaults --------
DEFAULT_PROVIDER=groq
DEFAULT_MODEL=llama-3.3-70b-versatile

# -------- Provider API keys (optional until used) --------
GROQ_API_KEY=
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
OPENROUTER_API_KEY=
DEEPSEEK_API_KEY=

# -------- Scraper Gateway --------
SCRAPER_URL=http://localhost:5300
SCRAPER_API_KEY=

# -------- App URLs --------
FRONTEND_URL=http://localhost:5173
BACKEND_PUBLIC_URL=http://localhost:8080

# -------- Stripe --------
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

# -------- Auth / Session --------
JWT_SECRET=change-me-to-a-long-random-secret
SESSION_SECRET=change-me-to-another-long-random-secret
ENCRYPTION_KEY=

# -------- GitHub OAuth --------
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
GITHUB_OAUTH_SCOPE=user:email
GITHUB_AUTH_SCOPE=user:email
GITHUB_DEPLOY_SCOPE=user:email repo
GITHUB_APP_ID=
GITHUB_PRIVATE_KEY=

# -------- Runtime --------
API_HOST=0.0.0.0
API_PORT=8080
SANDBOX_BASE_DIR=./sandbox

# -------- Database (Docker default from docker-compose.yml) --------
DATABASE_URL=postgresql://wagi:wagi123@localhost:5433/wagi
